# Polygon Amoy Testnet RPC (get free key from https://alchemy.com)
# Mumbai is deprecated — use Amoy (chainId: 80002)
BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/yqwjAdxW0yET9oa1zuMU4

# Polygon Mainnet RPC
BLOCKCHAIN_RPC_URL_MAINNET=https://polygon-mainnet.g.alchemy.com/v2/yqwjAdxW0yET9oa1zuMU4

# Private key of the DEPLOYER wallet (with MATIC for gas)
# NEVER commit the real value — add .env to .gitignore
BLOCKCHAIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Address of the backend HOT wallet that mints tokens (can be same as deployer)
MINTER_ADDRESS=0xYOUR_MINTER_ADDRESS

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_KEY

# Badge metadata base URI (IPFS or CDN)
BADGE_BASE_URI=https://citizora.app/badge-metadata/
